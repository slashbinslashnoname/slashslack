# Copy to .env and adjust
PORT=3000
NODE_ENV=production
# 32+ char secret used to encrypt session cookies
SESSION_SECRET=change-me-to-a-long-random-secret-string-please
# Where the SQLite database lives (mounted volume in Docker)
DATA_DIR=./data
# Where uploaded files live (mounted volume in Docker)
UPLOAD_DIR=./uploads
# Public origin, used for absolute URLs in link previews / uploads / invites
PUBLIC_ORIGIN=http://localhost:3000

# Image tag to deploy with docker-compose.prod.yml (latest | v1.2.3 | sha-xxxxxxx)
IMAGE_TAG=latest

# Optional SMTP for sending email invitations (left blank = copy-link fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SlashSlack <no-reply@example.com>
SMTP_SECURE=false
